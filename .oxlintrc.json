{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "plugins": ["react", "typescript"],
  "ignorePatterns": ["dist/**"],
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "vars": "all",
        "ignoreRestSiblings": true
      }
    ]
  }
}
